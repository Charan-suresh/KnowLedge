# Copy this to .env for local development
# Never commit .env - it contains secrets

# Inference - local development defaults (Ollama running on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_AUTH_TOKEN=

# Inference backend - choose one:
# "ollama"      local Ollama (for offline/local development)
# "hf_space"    Hugging Face Space (default for production)
# "gemini_api"  Google Gemini API (production fallback)
INFERENCE_BACKEND=hf_space

# Hugging Face Space URL (required when INFERENCE_BACKEND=hf_space)
# Format: "https://your-username-your-space-name.hf.space"
# Example: "https://charan-suresh-knowledge-inference.hf.space"
HF_SPACE_URL=

# Google Gemini API key (required when INFERENCE_BACKEND=gemini_api)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Models
SCOUT_MODEL=gemma4:e2b
SAGE_MODEL=gemma4:e4b
LENS_MODEL=gemma4:e4b

# Storage
DB_PATH=./knowledge.db
CHROMA_PATH=./chroma_store

# App
ENVIRONMENT=development
DEMO_MODE=true
SECRET_KEY=local-dev-secret-not-for-production
PORT=8000

# Sync (optional)
UNIVERSITY_SERVER_URL=
COURSE_ID=CS301

# Agents
SAGE_TIMEOUT_SECONDS=75
SOLO_TIMEOUT_SECONDS=300
LOW_RAM=true
